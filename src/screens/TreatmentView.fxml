<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="screens.TreatmentController">
    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>

    <Label text="💊 Gestion des Ordonnances"><font><Font name="System Bold" size="20.0" /></font></Label>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label style="-fx-font-weight: bold;" text="Choisir un Patient :" />
            <ComboBox fx:id="comboPatients" onAction="#handlePatientSelection" prefWidth="250.0" promptText="-- Sélectionner --" />
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-weight: bold;" text="🔍 Rechercher :" />
            <TextField fx:id="txtSearch" promptText="Tapez un médicament, type, posologie..." style="-fx-background-radius: 5;" HBox.hgrow="ALWAYS" />
        </HBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <TextField fx:id="txtMedicament" promptText="Nom du Médicament" HBox.hgrow="ALWAYS" />
        <TextField fx:id="txtType" promptText="Type" />
        <TextField fx:id="txtPosologie" promptText="Posologie" />
        <TextField fx:id="txtDateFin" promptText="Fin (AAAA-MM-JJ)" />
        <Button onAction="#addTreatment" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="➕ Prescrire" />
        <Button onAction="#updateTreatment" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;" text="✏Modifier" />
        <Button onAction="#deleteTreatment" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="🗑Supprimer" />
    </HBox>

    <TableView fx:id="tableTreatments" onMouseClicked="#handleTableSelection" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50" text="ID" />
            <TableColumn fx:id="colMedicament" prefWidth="180" text="Médicament" />
            <TableColumn fx:id="colType" prefWidth="100" text="Type" />
            <TableColumn fx:id="colPosologie" prefWidth="150" text="Posologie" />
            <TableColumn fx:id="colDateFin" prefWidth="120" text="Date Fin" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button onAction="#downloadPDF" style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 5;" text="📄 Générer l'Ordonnance (PDF)" />
    </HBox>
</VBox>
