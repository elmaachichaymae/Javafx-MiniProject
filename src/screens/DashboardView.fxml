<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="30.0" style="-fx-background-color: #ecf0f1;" styleClass="side-form" stylesheets="@../loginDesign.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="screens.DashboardController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

    <Label text="📈 Tableau de Bord Activité" textFill="#2c3e50">
        <font><Font name="System Bold" size="24.0" /></font>
    </Label>

    <HBox spacing="20.0">
        <VBox prefWidth="220.0" spacing="10.0" styleClass="bar" stylesheets="@../loginDesign.css" HBox.hgrow="ALWAYS">
            <Label text="👥 Total Patients" textFill="#2980b9">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Label fx:id="lblTotalPatients" text="0" textFill="#2c3e50">
                <font><Font name="System Bold" size="28.0" /></font>
            </Label>
        </VBox>

        <VBox prefWidth="220.0" spacing="10.0" styleClass="bar" stylesheets="@../loginDesign.css" HBox.hgrow="ALWAYS">
            <Label text="💊 Traitements Actifs" textFill="#27ae60">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Label fx:id="lblTraitementsActifs" text="0" textFill="#2c3e50">
                <font><Font name="System Bold" size="28.0" /></font>
            </Label>
        </VBox>

        <VBox prefWidth="220.0" spacing="10.0" styleClass="bar" stylesheets="@../loginDesign.css" HBox.hgrow="ALWAYS">
            <Label text="Ordonnances Expirées" textFill="#c0392b">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <Label fx:id="lblTraitementsExpires" text="0" textFill="#c0392b">
                <font><Font name="System Bold" size="28.0" /></font>
            </Label>
        </VBox>
    </HBox>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <VBox prefWidth="400.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #bdc3c7; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
            <Label text="📊 Répartition des Patients par Sexe" textFill="#2c3e50">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <PieChart fx:id="pieChartSexe" VBox.vgrow="ALWAYS" />
        </VBox>

        <VBox prefWidth="400.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #bdc3c7; -fx-border-radius: 8;" HBox.hgrow="ALWAYS">
            <Label text="⏱ Patients Récents" textFill="#2c3e50">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <TableView fx:id="tableRecentPatients" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colRecentNom" prefWidth="230.0" text="Nom du Patient" />
                    <TableColumn fx:id="colRecentSexe" prefWidth="100.0" text="Sexe" />
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>
